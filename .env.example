# Phase 1 compose stack -- env file template (M10.3 + iter-1).
#
# Copy to `.env` and fill in real values before running `make compose-up`.
# `.env` is .gitignored AND .dockerignored; only this template is tracked.
#
# Operator workflow:
#   1. cp .env.example .env
#   2. Edit .env with real values (issuer / admin creds).
#   3. mkdir -p secrets && chmod 700 secrets
#   4. openssl rand -hex 24    > secrets/postgres_password
#   5. openssl rand -base64 48 > secrets/keep_token_signing_key
#   6. chmod 600 secrets/*
#   7. make compose-up
#
# Iter-1 split: load-bearing secrets (Postgres password, Keep token
# signing key) live in `./secrets/<name>` files mounted via docker
# `secrets:`. Non-secret config (issuer string, admin username, knob
# overrides) stays in `.env` for visibility.

# ---------------------------------------------------------------------------
# Postgres -- non-secret components. The password lives in
# `./secrets/postgres_password` and is mounted via the `secrets:`
# block in docker-compose.yml.
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_DB=keep

# ---------------------------------------------------------------------------
# Keep service auth.
#
# KEEP_TOKEN_SIGNING_KEY is mounted via the `keep_token_signing_key`
# docker secret (./secrets/keep_token_signing_key). The file MUST hold
# a base64-encoded value that decodes to >= 32 bytes
# (config.MinTokenSigningKeyBytes). Mint via:
#
#   openssl rand -base64 48 > secrets/keep_token_signing_key
#
# KEEP_TOKEN_ISSUER is the expected `iss` claim on every verified
# token. Stable string; matches whatever the issuing service stamps.
# ---------------------------------------------------------------------------
KEEP_TOKEN_ISSUER=watchkeeper-dev

# ---------------------------------------------------------------------------
# Keep service DSN.
#
# The Keep service reads its Postgres DSN from either KEEP_DATABASE_URL
# (this env var) or KEEP_DATABASE_URL_FILE (a docker secret path).
# The compose default below assembles the DSN from the Postgres user
# (env) and the secret password file. Operators with a URI-reserved
# character in the password (`@`, `:`, `/`, `?`, `#`) should generate
# the password via `openssl rand -hex N` so the assembled DSN stays
# valid -- or set KEEP_DATABASE_URL_FILE to an operator-managed file
# that holds the pre-encoded DSN.
#
# Leave KEEP_DATABASE_URL empty and rely on the migrate sidecar +
# manual operator DSN file unless you know your password is URL-safe.
# A future M10.3.b will mount a pre-assembled DSN file so this knob
# can disappear.
# ---------------------------------------------------------------------------
KEEP_DATABASE_URL=postgres://postgres@postgres:5432/keep?sslmode=disable
KEEP_DATABASE_URL_FILE=

# ---------------------------------------------------------------------------
# Optional overrides. Defaults match config.Default*; uncomment to tune.
# ---------------------------------------------------------------------------
# KEEP_HTTP_ADDR=:8080
# KEEP_SHUTDOWN_TIMEOUT=10s
# KEEP_SUBSCRIBE_HEARTBEAT=15s
# KEEP_OUTBOX_POLL_INTERVAL=1s
# POSTGRES_SSLMODE=disable

# ---------------------------------------------------------------------------
# Grafana admin login. iter-1 #16: GF_SECURITY_ADMIN_PASSWORD is now
# REQUIRED via `${VAR:?...}` -- the historical `admin/admin` default
# was a foot-gun on stacks inherited between operators (the
# grafana_data volume persists the rotated password silently). Mint:
#
#   openssl rand -base64 24
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=
