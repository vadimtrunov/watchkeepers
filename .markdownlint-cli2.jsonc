{
  "config": {
    "default": true,
    "MD003": { "style": "atx" },
    "MD004": { "style": "dash" },
    "MD007": { "indent": 2 },
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD025": { "front_matter_title": "" },
    "MD026": { "punctuation": ".,;:!" },
    "MD033": false,
    "MD041": false,
    "MD046": { "style": "fenced" },
  },
  "globs": ["**/*.md"],
  "ignores": [
    "**/node_modules/**",
    "dist/**",
    "coverage/**",
    ".claude/**",
    ".omc/**",
    // Ephemeral task files (per .gitignore rdd rule)
    "TASK-*.md",
    // Pre-existing operator-authored docs — grandfathered.
    // Fix issues and remove from this list to opt back in.
    "docs/BACKLOG.md",
    "docs/ROADMAP-phase*.md",
    "docs/watchkeeper-business-concept.md",
    "docs/superpowers/**",
  ],
}
