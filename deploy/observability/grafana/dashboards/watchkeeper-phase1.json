{
  "uid": "watchkeeper-phase1",
  "title": "Watchkeeper -- Phase 1 starter",
  "tags": ["watchkeeper", "phase1", "m10.3"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "agent_id",
        "label": "Agent ID",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": {
          "query": "label_values(watchkeeper_llm_tokens_total, agent_id)",
          "refId": "agent_id"
        },
        "regex": "",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "refresh": 2,
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Keep HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP request rate by route + status class",
      "description": "rate of watchkeeper_http_request_duration_seconds_count by (route, status_class). 401 traffic visible after the M10.1 iter-1 wrap-order fix.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route, status_class) (rate(watchkeeper_http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{route}} - {{status_class}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP latency p50/p95/p99 (all routes)",
      "description": "histogram_quantile over watchkeeper_http_request_duration_seconds_bucket.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(watchkeeper_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(watchkeeper_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(watchkeeper_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Outbox + eventbus",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Outbox publish rate by outcome",
      "description": "rate of watchkeeper_outbox_published_total by (outcome). Success increments only after tx.Commit (M10.1 iter-1 fix); error includes batch-level failures.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(watchkeeper_outbox_published_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Eventbus queue depth by topic",
      "description": "watchkeeper_eventbus_queue_depth (gauge). Sustained growth indicates a slow subscriber.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "watchkeeper_eventbus_queue_depth",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "LLM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "LLM token spend by kind + provider (filtered by $agent_id)",
      "description": "rate of watchkeeper_llm_tokens_total by (kind, provider). Default groups by (kind, provider) only -- agent_id is filtered via the $agent_id template variable to bound cardinality on operator dashboards with many spawned agents (iter-1 #7).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": { "unit": "tokps" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind, provider) (rate(watchkeeper_llm_tokens_total{agent_id=~\"$agent_id\"}[5m]))",
          "legendFormat": "{{kind}} - {{provider}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "LLM request latency p95 by provider",
      "description": "histogram_quantile over watchkeeper_llm_request_duration_seconds_bucket.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(watchkeeper_llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p95"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Tools + messenger",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Tool invocation rate by tool + outcome",
      "description": "rate of watchkeeper_tool_invocations_total by (tool, outcome).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool, outcome) (rate(watchkeeper_tool_invocations_total[5m]))",
          "legendFormat": "{{tool}} - {{outcome}}"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Messenger rate-limit remaining by provider + endpoint",
      "description": "watchkeeper_messenger_rate_limit_remaining (gauge). Approaching zero is the operational warning signal for Slack/Jira throttling.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "watchkeeper_messenger_rate_limit_remaining",
          "legendFormat": "{{provider}} - {{endpoint}}"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Process (Keep)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Resident memory",
      "description": "process_resident_memory_bytes -- exposed by default; disable via wkmetrics.Options.DisableProcessCollectors when /metrics is on an unprotected listener.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Open file descriptors",
      "description": "process_open_fds (default ProcessCollector).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 37 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_open_fds",
          "legendFormat": "fds"
        }
      ]
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Goroutines",
      "description": "go_goroutines (default GoCollector).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 37 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_goroutines",
          "legendFormat": "goroutines"
        }
      ]
    }
  ]
}
